REM MK Term

WIDTH 80
SERIAL 19200,0
USETIMER 1000
INTERRUPT INKEY,IRKEY

WHILE 1
 A=SERIALIN()
 IF A>=0 THEN
  IF     A==$07 THEN
   REM BEL
   SOUND BEEP
  ELSEIF A==$08 OR A==$1D THEN
   REM BS/GS
   CURSOR SYSTEM(26)-1,SYSTEM(27):PRINT " ";
   CURSOR SYSTEM(26)-1,SYSTEM(27)
  ELSEIF A==$09 THEN
   REM HT
   X=(SYSTEM(26)/8)*8+8
   IF X>=SYSTEM(20) THEN X=SYSTEM(20)-1
   CURSOR X,SYSTEM(27)
  ELSEIF A==$0A OR A==$1F THEN
   REM LF/US
   Y=SYSTEM(27)+1
   IF Y>=SYSTEM(21) THEN Y=SYSTEM(21)-1:SCROLL 0,-1
   CURSOR SYSTEM(26),Y
  ELSEIF A==$0B OR A==$1E THEN
   REM REM VT/RS
   Y=SYSTEM(27)-1
   IF Y<0 THEN Y=0:SCROLL 0,1
   CURSOR SYSTEM(26),Y
  ELSEIF A==$0C THEN
   REM FF
   CLS
   CURSOR 0,0
  ELSEIF A==$0D THEN
   REM CR
   Y=SYSTEM(27)
   CURSOR 0,Y
  ELSEIF A==$1B THEN
   REM ESC
   PRINT "":PRINT "^";:PRINT CHR$($40+A);
  ELSEIF A==$1C THEN
   REM FS
   X=SYSTEM(26)+1
   IF X>=SYSTEM(20) THEN X=SYSTEM(20)-1
   CURSOR X,SYSTEM(27)
  ELSEIF A>=$1C AND A<=$F7 THEN
   PRINT CHR$(A);
  ELSE
   PRINT "":PRINT "^";:PRINT CHR$($40+A)
  ENDIF
 ENDIF
WEND

LABEL IRKEY
 VAR R,K,C,S
 R=READKEY()
 IF R==0 THEN RETURN
 C=(R >> 22) AND $01:  REM Capslock
 S=(R >> 16) AND $01:  REM Shift
 K=(R >>  8) AND $7F:  REM Virtual key code
 IF K==$08 THEN
  REM Back space
  SERIALOUT $08
 ELSEIF K==$09 THEN
  REM Tab
  SERIALOUT $09
 ELSEIF K==$10 OR K==$A0 OR K==$A1 THEN
  REM Shift (Ignore)
 ELSEIF K==$11 OR K==$A2 OR K==$A3 THEN
  REM Ctrl (Ignore)
 ELSEIF K==$12 OR K==$A4 OR K==$A5 THEN
  REM Alt (Ignore)
 ELSEIF K==$14 THEN
  REM CapsLock (Ignore)
 ELSEIF K==$0D THEN
  REM Enter
  SERIALOUT $0D
 ELSEIF K==$24 THEN
  REM Home
 ELSEIF K==$25 THEN
  REM Left
 ELSEIF K==$26 THEN
  REM Up
 ELSEIF K==$27 THEN
  REM Right
 ELSEIF K==$28 THEN
  REM Down
 ELSEIF K<$20 THEN
  PRINT HEX$(K)
  RETURN
 ELSEIF K<$3C THEN
  IF S==1 THEN K=K-$10
  SERIALOUT K
 ELSEIF K<$40 THEN
  IF S==0 THEN K=K-$10
  SERIALOUT K
 ELSEIF K<$5B THEN    
  IF C==1 THEN
   IF S==1 THEN K=K+$20 
  ELSE
   K=K+$20
   IF S==1 THEN K=K-$20    
  ENDIF
  SERIALOUT K
 ELSEIF K<$60 THEN
  IF S==1 THEN K=K+$20
  SERIALOUT K
 ENDIF
RETURN

LABEL BEEP
DATA $60557,1
